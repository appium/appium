{
  "extends": "@appium/tsconfig/tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "build",
    "checkJs": true,
    "strict": true,
    "types": ["chai", "chai-as-promised", "node"],
    "paths": {
      "@appium/types": ["../types"],
      "appium/support": ["../appium/support"],
      "appium/driver": ["../appium/driver"],
      "@appium/driver-test-support": ["../driver-test-support"]
    }
  },
  "include": ["lib", "test"],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../support"
    },
    {
      "path": "../driver-test-support"
    },
    {
      "path": "../base-driver"
    }
  ]
}
