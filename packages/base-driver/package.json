{
  "name": "@appium/base-driver",
  "version": "10.7.1",
  "description": "Base driver class for Appium drivers",
  "keywords": [
    "automation",
    "javascript",
    "selenium",
    "webdriver",
    "ios",
    "android",
    "firefoxos",
    "testing"
  ],
  "homepage": "https://appium.io",
  "bugs": {
    "url": "https://github.com/appium/appium/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/appium/appium.git",
    "directory": "packages/base-driver"
  },
  "license": "Apache-2.0",
  "author": "https://github.com/appium",
  "directories": {
    "lib": "lib"
  },
  "main": "./build/lib/index.js",
  "types": "./build/lib/index.d.ts",
  "files": [
    "lib",
    "test-fixtures",
    "build/lib",
    "tsconfig.json"
  ],
  "scripts": {
    "test": "run-p test:unit test:types",
    "test:e2e": "node --test --test-force-exit --test-concurrency=1 --test-timeout=20000 \"./build/test/e2e/**/*.spec.js\"",
    "test:smoke": "node ./build/lib/index.js",
    "test:unit": "node --test --test-timeout=5000 --test-concurrency=1 \"./build/test/unit/**/*.spec.js\"",
    "test:types": "tsd"
  },
  "dependencies": {
    "@appium/support": "7.2.5",
    "@appium/types": "1.5.1",
    "async-lock": "1.4.1",
    "asyncbox": "6.3.0",
    "axios": "1.18.0",
    "body-parser": "2.3.0",
    "express": "5.2.1",
    "fastest-levenshtein": "1.0.16",
    "http-status-codes": "2.3.0",
    "lru-cache": "11.5.1",
    "method-override": "3.0.0",
    "morgan": "1.11.0",
    "path-to-regexp": "8.4.2",
    "serve-favicon": "2.5.1",
    "type-fest": "5.7.0"
  },
  "optionalDependencies": {
    "spdy": "4.0.2"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "f7b20335eab4022e5cbbb627ec86866a994444f8",
  "tsd": {
    "directory": "test/types"
  }
