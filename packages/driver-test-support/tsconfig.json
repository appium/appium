{
  "extends": "@appium/tsconfig/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "rootDir": ".",
    "outDir": "build",
    "paths": {
      "@appium/types": [
        "../types"
      ],
      "appium/driver": [
        "../base-driver"
      ]
    },
    "types": [
      "chai",
      "chai-as-promised",
      "node"
    ]
  },
  "include": [
    "lib",
    "test"
  ],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../base-driver"
    }
  ]
}
