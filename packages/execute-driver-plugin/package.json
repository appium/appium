{
  "name": "@appium/execute-driver-plugin",
  "version": "6.0.6",
  "description": "Plugin for batching and executing Appium driver commands",
  "keywords": [
    "automation",
    "javascript",
    "selenium",
    "webdriver",
    "ios",
    "android",
    "firefoxos",
    "testing"
  ],
  "homepage": "https://appium.io",
  "bugs": {
    "url": "https://github.com/appium/appium/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/appium/appium.git",
    "directory": "packages/execute-driver-plugin"
  },
  "license": "Apache-2.0",
  "author": "https://github.com/appium",
  "main": "./build/lib/index.js",
  "types": "./build/lib/index.d.ts",
  "files": [
    "build/lib",
    "lib",
    "tsconfig.json"
  ],
  "scripts": {
    "test": "npm run test:unit",
    "test:e2e": "node --test --test-force-exit --test-timeout=160000 \"./build/test/e2e/**/*.spec.js\"",
    "test:smoke": "node ./build/lib/index.js",
    "test:unit": "node --test --test-timeout=5000 \"./build/test/unit/**/*.spec.js\""
  },
  "dependencies": {
    "@appium/support": "7.2.5",
    "webdriverio": "9.28.0"
  },
  "peerDependencies": {
    "appium": "^3.0.0-beta.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10"
  },
  "publishConfig": {
    "access": "public"
  },
  "appium": {
    "pluginName": "execute-driver",
    "mainClass": "ExecuteDriverPlugin"
  },
  "gitHead": "f7b20335eab4022e5cbbb627ec86866a994444f8"
}
